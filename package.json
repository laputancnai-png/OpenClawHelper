{
  "name": "openclaw-helper",
  "version": "0.1.0",
  "description": "A friendly GUI for OpenClaw multi-agent configuration",
  "private": true,
  "type": "module",
  "scripts": {
    "dev":   "concurrently -n \"UI,FILES\" -c \"cyan,green\" \"vite\" \"node server/server.mjs\"",
    "dev:ui":     "vite",
    "dev:server": "node server/server.mjs",
    "build": "tsc --noEmit && vite build",
    "start": "node server/server.mjs",
    "preview": "vite preview",
    "mock": "concurrently -n \"MOCK,FILES\" -c \"yellow,green\" \"node mock/mock-gateway.mjs\" \"node server/server.mjs\""
  },
  "dependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.0.0",
    "concurrently": "^9.0.0",
    "typescript": "^5.0.0",
    "vite": "^6.0.0",
    "ws": "^8.0.0"
  }
}
